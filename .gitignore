# =====================
# Trivy
# =====================
.trivyignore

# =====================
# Terraform
# =====================
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.lock.hcl
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.tfplan
tfplan
.terraformrc
terraform.rc

# 환경별 변수 파일 (민감정보 포함 가능)
*.auto.tfvars
terraform.tfvars
!terraform.tfvars.example

# =====================
# Ansible
# =====================
*.retry
ansible/vault_password_file
ansible/vault_pass
*.vault
.vault_pass

# 인벤토리 파일 (호스트 정보 포함)
ansible/inventory/production
ansible/inventory/staging
!ansible/inventory/example

# =====================
# Kubernetes / Helm
# =====================
kubeconfig
*.kubeconfig
.kube/
helm/charts/
**/charts/*.tgz

# =====================
# Docker
# =====================
.docker/
docker-compose.override.yml

# =====================
# AWS
# =====================
.aws/
aws-exports.js
*.pem
*.key
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub

# =====================
# Secrets / Credentials
# =====================
.env
.env.*
!.env.example
*.secret
secrets/
secret.yaml
secret.yml
*-secret.yaml
*-secret.yml

# =====================
# OS
# =====================
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# =====================
# IDE / Editor
# =====================
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json        # 공유 권장 익스텐션 목록은 허용
.idea/
*.swp
*.swo
*~

# =====================
# Logs
# =====================
*.log
logs/

# =====================
# Python (Ansible 의존성)
# =====================
__pycache__/
*.pyc
*.pyo
.venv/
venv/