upstream whoami_backend {
    server 127.0.0.1:{{ whoami_container_host_port }};
}

upstream app_backend {
    server {{ app_private_ip }}:{{ app_port }};
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name _;

    # Nginx health check — no upstream required
    location /healthz {
        return 200 "OK\n";
        add_header Content-Type text/plain;
        access_log off;
    }

    # Network test container — accessible via /test on port 80
    location /test {
        proxy_pass http://whoami_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Main reverse proxy to app tier
    location / {
        proxy_pass http://app_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;
    }
}
